NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_WORKSPACE_ID=00000000-0000-0000-0000-000000000000
JWT_SECRET=replace-with-a-secure-secret
# Optional. Custom auth users file path for register/login local storage.
# In production, if not provided, auth storage defaults to /tmp/recuperaventas-dashboard/users.json
AUTH_USERS_FILE_PATH=
# Optional. Custom storage file for workspace AI chatbot settings.
# In production, if not provided, settings storage defaults to
# /tmp/recuperaventas-dashboard/workspace-settings.json
WORKSPACE_SETTINGS_FILE_PATH=
