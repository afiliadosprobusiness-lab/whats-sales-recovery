NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/recuperaventas
REDIS_URL=redis://localhost:6379
WHATSAPP_SESSION_DATA_PATH=.wwebjs_auth
ABANDONED_THRESHOLD_MINUTES=30
IDLE_THRESHOLD_HOURS=24
RECOVERY_TEMPLATE_TEXT=Hola 👋 Ayer preguntaste por el producto. ¿Te ayudo a terminar tu pedido?
LOG_LEVEL=info
WHATSAPP_INBOUND_DIAGNOSTIC_MODE=false
OPENAI_API_KEY=
